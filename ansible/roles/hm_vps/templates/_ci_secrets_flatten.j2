{# Recursive flatten: secrets subtree -> UPPER_SNAKE stringData lines for hm-ci Secret. #}
{% macro emit(prefix, node) -%}
{% if node is mapping %}
{% for k, v in node.items() %}
{{- emit(prefix + [k | string], v) -}}
{% endfor %}
{% elif node is none %}
{% elif node is boolean %}
  {{ (prefix | map('string') | join('_') | upper) }}: {{ 'true' if node else 'false' }}
{% elif node is number %}
  {{ (prefix | map('string') | join('_') | upper) }}: {{ node | string }}
{% else %}
  {{ (prefix | map('string') | join('_') | upper) }}: {{ node | to_json }}
{% endif %}
{%- endmacro %}
{% for root in hm_ci_secret_roots %}
{% set sub = hm_local_env.secrets[root] | default(none) %}
{% if sub is mapping and sub | length > 0 %}
{{ emit([root | string], sub) }}
{% endif %}
{% endfor %}
